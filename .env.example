# --- Bot Discord ---
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here
DISCORD_REDIRECT_URL=http://localhost:8080/auth/callback

# --- Base de données MariaDB ---
# En développement local sans Docker : utiliser DB_HOST=localhost DB_PORT=3307
DB_HOST=mariadb
DB_PORT=3306
DB_USER=discordbot
DB_PASSWORD=changeme
DB_NAME=discordbot
DB_ROOT_PASSWORD=rootchangeme

# --- Dashboard web ---
HTTP_ADDR=:8080
# SESSION_SECRET doit faire au moins 32 caractères
SESSION_SECRET=change_me_to_a_random_32_char_secret

# --- Cache ---
# Durée en secondes avant expiration d'une entrée de cache de config guilde
CACHE_TTL_SECONDS=300

# --- Logs ---
# Niveaux : debug | info | warn | error
LOG_LEVEL=info
